# Agent Smith - Environment Variables
# Copy this file to .env and fill in your values.
# Only the keys relevant to your configured agent/source/ticket types are needed.

# --- AI Provider API Keys (at least one, depending on agent.type in config) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_API_KEY=...
# GEMINI_API_KEY=...
# GROQ_API_KEY=gsk_...

# --- Source / Ticket Provider Tokens (depending on source.type / tickets.type) ---
# GITHUB_TOKEN=ghp_...
# AZURE_DEVOPS_TOKEN=...
# GITLAB_TOKEN=glpat-...
# GITLAB_URL=https://gitlab.com
# GITLAB_PROJECT=mygroup/myproject

# --- Jira (required if tickets.type is "jira") ---
# JIRA_URL=https://mycompany.atlassian.net
# JIRA_EMAIL=user@example.com
# JIRA_TOKEN=...
# JIRA_WEBHOOK_SECRET=...
