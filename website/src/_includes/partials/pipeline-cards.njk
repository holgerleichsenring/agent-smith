{# Pipeline-tint mapping per DESIGN.md: cream = code-changing pipelines, dark = severity/admin pipelines. #}
{% set tintMap = {
  "fix": "cream",
  "feature": "cream",
  "legal": "cream",
  "mad": "cream",
  "init": "cream",
  "security": "dark",
  "api": "dark",
  "autonomous": "dark",
  "skill-manager": "dark",
  "custom": "cream"
} %}

<section class="pipelines-section" id="pipelines">
  <div class="section-wrap">
    <div class="section-eyebrow">Pipelines</div>
    <h2 class="section-title">Start fast. Customize everything.</h2>
    <p class="section-sub">Prebuilt pipelines for coding, security, and more — or define your own in <code class="inline-code">agentsmith.yml</code>.</p>
    <div class="pipeline-grid">
      {% for p in pipelines %}
      {% set tint = tintMap[p.id] or "cream" %}
      <article class="pipeline-card pipeline-card--{{ tint }}{% if p.dashed %} pipeline-card--outlined{% endif %}">
        <div class="pipeline-card-cmd">{{ p.cmd }}</div>
        <h3 class="pipeline-card-name">{{ p.name }}</h3>
        <p class="pipeline-card-desc">{{ p.desc | safe }}</p>
        <div class="pipeline-card-tags">
          {% for tag in p.tags %}<span class="pipeline-tag{% if tag.green %} pipeline-tag--green{% endif %}">{{ tag.text | safe }}</span>{% endfor %}
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
