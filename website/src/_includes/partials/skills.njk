<section class="skills-section" id="skills">
  <div class="section-wrap">
    <div class="section-label">Multi-Skill Architecture</div>
    <h2 class="section-title">Specialists, not generalists.</h2>
    <p class="section-sub">Roles defined in YAML files. Each has its own perspective, rules, and convergence criteria. Triage selects who's relevant. Add your own in minutes.</p>
    <div class="skills-grid">
      <div class="skill-domains">
        {% for s in skills %}
        <div class="skill-domain"{% if s.dashed %} style="border-style:dashed"{% endif %}>
          <div class="skill-domain-icon">{{ s.icon | safe }}</div>
          <div>
            <div class="skill-domain-name">{{ s.name }}</div>
            <div class="skill-domain-roles">{{ s.roles | safe }}</div>
