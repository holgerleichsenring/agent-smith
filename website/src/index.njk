<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-badge"><div class="hero-badge-dot"></div>MIT &middot; Open Source &middot; Self-hosted</div>
    <h1>AI-powered<br>pipeline <em>execution.</em></h1>
    <p class="hero-sub">
      Define pipelines as chains of steps. Each step can run an AI agent, spawn a multi-role discussion, call tools, or move files. Ticket to PR &mdash; fully automated.
    </p>
    <div class="hero-actions">
      <a href="{{ site.docsUrl }}/getting-started/" class="btn-hero">Get started free &rarr;</a>
      <a href="{{ site.docsUrl }}" class="btn-hero-ghost">Read the docs</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <a href="https://github.com/{{ site.githubRepo }}" target="_blank" rel="noopener">
          <svg class="gh-star-icon" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"/></svg>
          <span id="gh-stars">&mdash;</span> stars
        </a>
      </div>
      <div class="hero-meta-item"><strong>{{ pipelines | length }}</strong> pipeline presets</div>
      <div class="hero-meta-item"><strong>{{ providers | length }}</strong> AI providers</div>
      <div class="hero-meta-item"><strong>$0</strong> SaaS fees</div>
      <div class="hero-meta-item"><strong>MIT</strong> license</div>
