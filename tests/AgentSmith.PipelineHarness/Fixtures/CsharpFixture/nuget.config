<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Same Azure DevOps feed shape the operator uses, so the host-match
         logic exercises the dot-boundary rule. Real-tier docker tests
         attempt restore; fast-tier tests just verify that
         SetupRegistryAuth wrote ~/.nuget/NuGet/NuGet.Config for this
         source name. -->
    <add key="fixture-private-feed" value="https://pkgs.dev.azure.com/agent-smith-fixtures/_packaging/private/nuget/v3/index.json" />
  </packageSources>
</configuration>
